# --------------------------------------------------------------------
# STM32CubeMX — Automatically Generated Files Only
# --------------------------------------------------------------------

# 1. CubeMX project metadata (regenerated anytime with .ioc)
*.mxproject
*.mxproject/*
*.osx.project

# 2. Code generation logs
*.log

# 3. Build artifacts from CubeMX-created projects
# (Object files, dependency files, build directories)
**/*.o
**/*.d
**/*.elf
**/*.map
**/*.hex
**/*.bin
**/*.list
**/*.out

# Typical build directories
build/
Debug/
Release/
EWARM/Settings/
EWARM/Obj/
EWARM/Exe/
MDK-ARM/*.uvguix.*         # uvguix backup state files (regenerated)
MDK-ARM/*.uvoptx           # target options (auto-regenerated)
MDK-ARM/Objects/
MDK-ARM/Listings/
MDK-ARM/*.dep
AC6/Debug/
AC6/Release/

# 4. IDE-specific auto-generated metadata (CubeIDE regenerates these)
.settings/
.cproject
.project
.loadpath

# 5. Autogenerated Makefiles (CubeMX overwrites these)
Makefile
makefile

# 6. CubeIDE launch configurations (auto-recreated)
*.launch

# 7. C/C++ language server index files
.vscode/
.ipynb_checkpoints/
*.idx
*.pyc

# 8. OS junk
.DS_Store
Thumbs.db